# Copy this to vars.pkrvars.hcl and fill in your values.
# vars.pkrvars.hcl is gitignored — never commit the real one.
#
# Run the build with:
#   packer build -var-file=vars.pkrvars.hcl lando-calrissian.pkr.hcl

# ---- Proxmox -----------------------------------------------------------------
# Create an API token in the Proxmox web UI:
#   Datacenter → Permissions → API Tokens → Add
# Required permissions: VM.Allocate, VM.Clone, VM.Config.*, Datastore.AllocateSpace, Sys.Modify

proxmox_url      = "https://YOUR_PROXMOX_IP:8006/api2/json"
proxmox_username = "packer@pve!packer"   # user@realm!tokenid
proxmox_token    = "your-token-secret"
proxmox_node     = "pve"                 # node name shown in Proxmox UI

# ---- VM ----------------------------------------------------------------------

vm_id        = 9000
vm_name      = "lando-calrissian"
storage_pool = "data"
bridge       = "vmbr0"
cores        = 2
memory       = 2048
disk_size    = "20G"

# ---- OS image ----------------------------------------------------------------
# Download the latest Debian netinstall ISO URL + checksum from:
# https://www.debian.org/CD/netinst/

iso_url      = "https://cdimage.debian.org/debian-cd/current/amd64/iso-cd/debian-13.x.x-amd64-netinst.iso"
iso_checksum = "sha256:xxxxxxxxxxxx"

# ---- Guest user --------------------------------------------------------------
# This user will own the compose stacks on every cloned VM.
# compose_user_password is only used during the Packer build for the initial
# SSH connection — once the SSH public key is in place, password auth can be
# disabled.

compose_user          = "your-username"
compose_user_password = "temporary-build-password"
ssh_public_key        = "ssh-ed25519 AAAA... your-key-comment"

# ---- NAS ---------------------------------------------------------------------

nas_ip    = "192.168.1.100"
nas_share = "homelab-backups"

# ---- Tailscale ---------------------------------------------------------------
# Tailscale is installed by Packer but NOT enrolled here — enrollment happens
# at first boot via the cloud-init snippet generated by restore-stacks.
# Set TAILSCALE_AUTH_KEY in .env (repo root), not here.
