# Copy this to .env and fill in your values.
# .env is gitignored — never commit the real one.
# restore-stacks sources this automatically from the repo root.

# VMID of the lando-calrissian template (built by Packer).
TEMPLATE_ID=9000

# Non-root user baked into the template — owns the compose stacks.
COMPOSE_USER=your-username

# NAS share where backups land.
NAS_IP=192.168.1.100
NAS_SHARE=homelab-backups

# URL that returns your SSH public keys — injected into each new VM via cloud-init.
# GitHub exposes these at https://github.com/your-username.keys
# Required: restore-stacks will fail if unset or the URL returns empty.
SSH_KEYS_URL=https://github.com/your-username.keys

# Tailscale reusable auth key — used in the cloud-init snippet to enroll
# each new VM in Tailscale on first boot. Leave empty to skip.
TAILSCALE_AUTH_KEY=tskey-auth-xxxxxxxxxxxx
